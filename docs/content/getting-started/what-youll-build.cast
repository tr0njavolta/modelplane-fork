[0.000, "o", "\u001b[38;2;248;248;242m          \u001b[0m\u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m A100 40GB (40960Mi) qualifies; L4 (23034Mi) does not.\u001b[0m\r\n\u001b[38;2;248;248;242m          \u001b[0m\u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m Threshold at 35Gi not 40Gi to avoid the boundary on A100's exact reported VRAM.\u001b[0m\r\n"]
