[0.523, "o", "\u001b]10;?\u0007\u001b]11;?\u0007\u001b[c"]
[1.014, "o", "\u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m A second ModelDeployment, pinned to a different region with clusterSelector.\u001b[0m\r\n\u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m It carries its own deployment name, so the ModelService can front it alongside\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m qwen-demo and serve both from one endpoint.\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;249;38;114mapiVersion\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mmodelplane.ai/v1alpha1\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;249;38;114mkind\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mModelDeployment\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;249;38;114mmetadata\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114mname\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mqwen-west\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114mnamespace\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mml-team\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;249;38;114mspec\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114mreplicas\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;190;132;255m1\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m clusterSelector filters which InferenceClusters this deployment can land on.\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;117;113;94m#\u001b[0m\u001b[38;2;117;113;94m This pins the replica to the us-west cluster you added in \"Scale the fleet\".\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;248;248;242m  \u001b[0m\u001b[38;2;249;38;114mclusterSelector\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\r\n\u001b[38;2;248;248;242m    \u001b[0m\u001b[38;2;249;38;114mmatchLabels\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\r\n"]
[0.000, "o", "\u001b[38;2;248;248;242m      \u001b[0m\u001b[38;2;249;38;114mmodelplane.ai/region\u001b[0m\u001b[38;2;248;248;242m:\u001b[0m\u001b[38;2;248;248;242m \u001b[0m\u001b[38;2;230;219;116mus-west\u001b[0m\r\n"]
